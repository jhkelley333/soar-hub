# Public — safe to ship to the browser. These are scoped by Supabase RLS.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only (Netlify Functions). Never prefix with VITE_.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Resend (transactional email). The PAF flow sends notifications via
# the Resend HTTP API; without RESEND_API_KEY set, emails are skipped
# (no-op, with a console warning) and the user-facing actions still
# succeed. Verify your sending domain in Resend before turning this on.
RESEND_API_KEY=
RESEND_FROM_EMAIL=paf@mysoarhub.com
RESEND_FROM_NAME=SOAR PAF
# Optional. Override Reply-To if you want replies to land elsewhere
# than the From address.
RESEND_REPLY_TO=

# --- Everything below is optional / feature-specific. Full reference,
#     including which vars are required, is in docs/ENV.md. ---

# Per-module email sender overrides (default to the RESEND_* values above).
# CASH_FROM_NAME=
# FACILITIES_FROM_NAME=
# WALKTHROUGH_FROM_NAME=
# EMPLOYEE_ACTIONS_FROM_NAME=
# WORKSPACE_FROM_NAME=

# Google — Sheets/Drive reads (Labor, Ranker, Vendors, Resources) + Maps.
# GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_MAPS_API_KEY=
# GOOGLE_GEOCODING_API_KEY=
# RESOURCES_ROOT_FOLDER_ID=

# Territory Map (browser-side; VITE_ prefix ships to the client).
# VITE_GOOGLE_MAPS_API_KEY needs the Maps JavaScript API enabled and should
# be HTTP-referrer restricted. VITE_GOOGLE_MAPS_MAP_ID is optional — a
# custom Map ID for styling; the page falls back to DEMO_MAP_ID.
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_GOOGLE_MAPS_MAP_ID=

# Web push (PWA notifications).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@mysoarhub.com

# SMS — Telnyx (PAF "Text approver"). Outbound only; no inbound webhook.
# Set the API key + ONE sender (a number, or a messaging profile id).
# TELNYX_API_KEY=
# TELNYX_FROM_NUMBER=+14695551234
# TELNYX_MESSAGING_PROFILE_ID=

# Misc.
# ANTHROPIC_API_KEY=
# LABOR_SHEET_ID=
# Planned: shared secret to guard internal/scheduled functions (see docs/ENV.md).
# CRON_SECRET=
